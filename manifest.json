{
  "manifest_version": 3,
  "name": "Job Application Copilot",
  "version": "1.0.0",
  "description": "AI-powered job application assistant that optimizes resumes, analyzes job descriptions, and helps you apply smarter",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "dist/background/background.js",
    "type": "module",
    "persistent": false
  },
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "options_page": "dist/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["dist/content/content.js"],
      "css": ["dist/content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "assets/*", "features/*", "dashboard.html", "dashboard.js", "welcome.html", "dist/*"],
      "matches": ["<all_urls>"],
      "extension_ids": []
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "minimum_chrome_version": "88",
  "incognito": "not_allowed",
  "commands": {
    "toggle-copilot": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Toggle the Job Copilot overlay"
    }
  }
}