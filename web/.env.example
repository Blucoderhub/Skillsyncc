# Database Connection
# Replace with your actual database URL (Vercel Postgres, Supabase, or local)
POSTGRES_URL="postgresql://username:password@localhost:5432/skillsyncc"

# JWT Secret for Authentication
# Change this to a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# AI Providers (At least one is required for AI features)
OPENAI_API_KEY="sk-your-openai-key"
ANTHROPIC_API_KEY="sk-ant-your-api-key"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Development Mode
NODE_ENV="development"
